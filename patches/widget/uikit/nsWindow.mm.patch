+void nsWindow::DispatchTouchStart(WidgetTouchEvent* aEvent,
+                                  uint64_t aSequenceId) {
+  MOZ_ASSERT(NS_IsMainThread());
+
+  if (!mAPZC) {
+    DispatchEvent(aEvent);
+    return;
+  }
+
+  APZInputBridge::InputBlockCallback callback =
+      [window = RefPtr{this}, aSequenceId](
+          uint64_t, const APZHandledResult& aHandledResult) {
+        window->NotifyAPZInputResult(aSequenceId, aHandledResult);
+      };
+  APZEventResult result =
+      mAPZC->InputBridge()->ReceiveInputEvent(*aEvent, std::move(callback));
+
+  if (result.GetStatus() != nsEventStatus_eConsumeNoDefault) {
+    ProcessUntransformedAPZEvent(aEvent, result);
+  }
+
+  if (result.GetHandledResult()) {
+    NotifyAPZInputResult(aSequenceId, result.GetHandledResult().ref());
+  }
+}
+
+void nsWindow::NotifyAPZInputResult(uint64_t aSequenceId,
+                                    const APZHandledResult& aHandledResult) {
+  if (!mNativeView) {
+    return;
+  }
+
+  GeckoInputHandling handling = GeckoInputHandlingUnhandled;
+  switch (aHandledResult.mPlace) {
+    case APZHandledPlace::HandledByRoot:
+      handling = GeckoInputHandlingBrowser;
+      break;
+    case APZHandledPlace::HandledByContent:
+      handling = GeckoInputHandlingContent;
+      break;
+    case APZHandledPlace::Unhandled:
+      break;
+    case APZHandledPlace::Invalid:
+      return;
+  }
+
+  GeckoScrollableEdges scrollableEdges = 0;
+  if (aHandledResult.mScrollableDirections & SideBits::eTop) {
+    scrollableEdges |= GeckoScrollableEdgeTop;
+  }
+  if (aHandledResult.mScrollableDirections & SideBits::eRight) {
+    scrollableEdges |= GeckoScrollableEdgeRight;
+  }
+  if (aHandledResult.mScrollableDirections & SideBits::eBottom) {
+    scrollableEdges |= GeckoScrollableEdgeBottom;
+  }
+  if (aHandledResult.mScrollableDirections & SideBits::eLeft) {
+    scrollableEdges |= GeckoScrollableEdgeLeft;
+  }
+
+  GeckoOverscrollAxes overscrollAxes = 0;
+  if (aHandledResult.mOverscrollDirections.contains(
+          HorizontalScrollDirection)) {
+    overscrollAxes |= GeckoOverscrollAxisHorizontal;
+  }
+  if (aHandledResult.mOverscrollDirections.contains(VerticalScrollDirection)) {
+    overscrollAxes |= GeckoOverscrollAxisVertical;
+  }
+
+  [mNativeView resolveTouchSequence:aSequenceId
+                           handling:handling
+                    scrollableEdges:scrollableEdges
+                     overscrollAxes:overscrollAxes];
+}
