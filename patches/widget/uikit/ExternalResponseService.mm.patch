+class ExternalResponseListener final : public nsIStreamListener,
+                                       public nsIInterfaceRequestor,
+                                       public nsIChannelEventSink {
+ public:
+  explicit ExternalResponseListener(nsWindow* aWindow) : mWindow(aWindow) {
+    MOZ_ASSERT(aWindow);
+  }
+
+  NS_DECL_THREADSAFE_ISUPPORTS
+  NS_DECL_NSIREQUESTOBSERVER
+  NS_DECL_NSISTREAMLISTENER
+  NS_DECL_NSIINTERFACEREQUESTOR
+  NS_DECL_NSICHANNELEVENTSINK
+
+  enum class DecisionType {
+    Initial,
+    Progress,
+  };
+
+  void HandleDecision(nsIRequest* aRequest, DecisionType aType,
+                      bool aShouldContinue);
+
+ private:
+  ~ExternalResponseListener() = default;
+
+  nsresult BeginCapturingResponseBody();
+  void CleanupCapturedResponseBody();
+  nsresult DispatchExternalResponse(nsIChannel* aChannel,
+                                    nsIGeckoViewEventCallback* aCallback);
+  nsresult DispatchProgress(nsIRequest* aRequest);
+  nsresult DispatchCompletion(bool aSucceeded);
+
+  RefPtr<nsWindow> mWindow;
+  nsCOMPtr<nsIFile> mCapturedResponseFile;
+  nsCOMPtr<nsIOutputStream> mCapturedResponseStream;
+  uint64_t mCapturedBytes = 0;
+  TimeStamp mLastProgressReport;
+  bool mIsCapturingResponseBody = false;
+};
+
+NS_IMPL_ISUPPORTS(ExternalResponseListener, nsIStreamListener,
+                  nsIInterfaceRequestor, nsIChannelEventSink)
+
+class ExternalResponseDecisionCallback final
+    : public nsIGeckoViewEventCallback {
+ public:
+  ExternalResponseDecisionCallback(ExternalResponseListener* aListener,
+                                   nsIRequest* aRequest,
+                                   ExternalResponseListener::DecisionType aType)
+      : mListener(aListener), mRequest(aRequest), mType(aType) {}
+
+  NS_DECL_ISUPPORTS
+
+  NS_IMETHOD OnSuccess(JS::Handle<JS::Value> aData, JSContext* aCx) override {
+    mListener->HandleDecision(mRequest, mType,
+                              aData.isBoolean() && aData.toBoolean());
+    return NS_OK;
+  }
+
+  NS_IMETHOD OnError(JS::Handle<JS::Value> aData, JSContext* aCx) override {
+    mListener->HandleDecision(mRequest, mType, false);
+    return NS_OK;
+  }
+
+ private:
+  ~ExternalResponseDecisionCallback() = default;
+
+  RefPtr<ExternalResponseListener> mListener;
+  nsCOMPtr<nsIRequest> mRequest;
+  ExternalResponseListener::DecisionType mType;
+};
