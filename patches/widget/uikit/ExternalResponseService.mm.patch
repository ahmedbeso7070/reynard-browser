+mozilla::StaticRefPtr<ExternalResponseService>
+    ExternalResponseService::sService;
+
+already_AddRefed<ExternalResponseService>
+ExternalResponseService::GetSingleton() {
+  if (!sService) {
+    sService = new ExternalResponseService();
+  }
+
+  RefPtr<ExternalResponseService> service = sService;
+  return service.forget();
+}
