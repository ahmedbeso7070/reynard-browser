+#include "PictureInPictureSupport.h"
+
+#import <AVFoundation/AVFoundation.h>
+
+#include <utility>
+
+#include "mozilla/layers/NativeLayerCA.h"
+#include "mozilla/layers/NativeLayerCAPictureInPicture.h"
+#include "mozilla/widget/EventDispatcher.h"
+#include "nsWindow.h"
+
+using namespace mozilla;
+using namespace mozilla::layers;
+using namespace mozilla::widget;
+
+@interface GeckoViewPictureInPictureSnapshot () {
+  AVSampleBufferDisplayLayer* _displayLayer;
+  uint64_t _enqueueCount;
+  BOOL _fullscreen;
+}
+- (instancetype)initWithDisplayLayer:(AVSampleBufferDisplayLayer*)displayLayer
+                        enqueueCount:(uint64_t)enqueueCount
+                          fullscreen:(BOOL)fullscreen;
+@end
+
+@implementation GeckoViewPictureInPictureSnapshot
+- (instancetype)initWithDisplayLayer:(AVSampleBufferDisplayLayer*)displayLayer
+                        enqueueCount:(uint64_t)enqueueCount
+                          fullscreen:(BOOL)fullscreen {
+  self = [super init];
+  if (self) {
+    _displayLayer = [displayLayer retain];
+    _enqueueCount = enqueueCount;
+    _fullscreen = fullscreen;
+  }
+  return self;
+}
+
+- (AVSampleBufferDisplayLayer*)displayLayer {
+  return _displayLayer;
+}
+
+- (uint64_t)enqueueCount {
+  return _enqueueCount;
+}
+
+- (BOOL)fullscreen {
+  return _fullscreen;
+}
+
+- (void)dealloc {
+  [_displayLayer release];
+  [super dealloc];
+}
+@end
+
+@interface GeckoViewPictureInPictureCandidateList () {
+  NSArray<GeckoViewPictureInPictureSnapshot*>* _candidates;
+}
+- (instancetype)initWithCandidates:
+    (NSArray<GeckoViewPictureInPictureSnapshot*>*)candidates;
+@end
+
+@implementation GeckoViewPictureInPictureCandidateList
+- (instancetype)initWithCandidates:
+    (NSArray<GeckoViewPictureInPictureSnapshot*>*)candidates {
+  self = [super init];
+  if (self) {
+    _candidates = [candidates retain];
+  }
+  return self;
+}
+
+- (NSUInteger)count {
+  return _candidates.count;
+}
+
+- (GeckoViewPictureInPictureSnapshot*)candidateAtIndex:(NSUInteger)index {
+  return [_candidates objectAtIndex:index];
+}
+
+- (void)dealloc {
+  [_candidates release];
+  [super dealloc];
+}
+@end
+
+namespace mozilla::widget {
+
+void InstallPictureInPictureLayerObserver(nsWindow* aWindow) {
+  NativeLayerRoot* nativeLayerRoot = aWindow->GetNativeLayerRoot();
+  NativeLayerRootCA* root =
+      nativeLayerRoot ? nativeLayerRoot->AsNativeLayerRootCA() : nullptr;
+  EventDispatcher* eventDispatcher = aWindow->GetEventDispatcher();
+  if (!root || !eventDispatcher) {
+    return;
+  }
+  RefPtr<EventDispatcher> dispatcher = eventDispatcher;
+  root->SetPictureInPictureLayerChangedCallback(
+      [dispatcher = std::move(dispatcher)]() {
+        dispatcher->DispatchToEmbedder(
+            u"GeckoView:PictureInPicture:LayerChanged"_ns);
+      });
+}
+
+GeckoViewPictureInPictureCandidateList* GetPictureInPictureCandidates(
+    nsWindow* aWindow) {
+  if (!aWindow) {
+    return nil;
+  }
+  NativeLayerRoot* nativeLayerRoot = aWindow->GetNativeLayerRoot();
+  NativeLayerRootCA* root =
+      nativeLayerRoot ? nativeLayerRoot->AsNativeLayerRootCA() : nullptr;
+  if (!root) {
+    return nil;
+  }
+  nsTArray<PictureInPictureCandidate> nativeCandidates =
+      root->CopyPictureInPictureCandidates();
+  NSMutableArray<GeckoViewPictureInPictureSnapshot*>* candidates =
+      [NSMutableArray arrayWithCapacity:nativeCandidates.Length()];
+  for (const auto& nativeCandidate : nativeCandidates) {
+    GeckoViewPictureInPictureSnapshot* candidate =
+        [[[GeckoViewPictureInPictureSnapshot alloc]
+            initWithDisplayLayer:(AVSampleBufferDisplayLayer*)
+                                     nativeCandidate.Layer()
+                    enqueueCount:nativeCandidate.EnqueueCount()
+                      fullscreen:nativeCandidate.IsFullscreen()] autorelease];
+    [candidates addObject:candidate];
+  }
+  return [[[GeckoViewPictureInPictureCandidateList alloc]
+      initWithCandidates:candidates] autorelease];
+}
+
+}  // namespace mozilla::widget
